    <fieldUpdates>
        <fullName>Initiate_Approval</fullName>
        <field>Approval_Step__c</field>
        <formula>IF(
    ISPICKVAL(Project_Leadxx__c, &quot;Housing Analyst&quot;),
    &quot;Housing Analyst&quot;,
    IF(
        ISPICKVAL(Project_Leadxx__c, &quot;Program Monitor&quot;),
        &quot;Program Monitor&quot;,
        &quot;Program Admin&quot;
    )
)</formula>
        <name>Initiate Approval</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Program_Admin_Queue_Change</fullName>
        <field>Approval_Step__c</field>
