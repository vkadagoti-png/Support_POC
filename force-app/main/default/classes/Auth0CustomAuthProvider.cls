/*
*********************************************************
Apex Class Name    : Auth0CustomAuthProvider
Created Date       : 08/19/2025
Author             : Omniskope Inc.
Description        : This Apex class implements the Auth.AuthProviderPluginClass interface to create a custom authentication provider for Auth0.
                     It handles the full OAuth 2.0 flow, from initiating the authentication request to retrieving the user's information.
*********************************************************
*/
   global class Auth0CustomAuthProvider extends Auth.AuthProviderPluginClass {

    //This is the URL for the endpoint that the authentication provider calls back to for configuration.It is automatically populated by Salesforce.
    public String redirectUrl;
    private String key;
    private String secret;
       
    // authentication and authorization.
    private String authUrl;
    
    // URI to get the new access token from Auth0 using the GET verb.
    private String accessTokenUrl;
    
    // Api name for the custom metadata type created for this auth provider.
    private String customMetadataTypeApiName;
    
    // Api URL to access the user in Auth0
    private String userAPIUrl;
    
    // Version of the user api URL to access data from Auth0
    private String userAPIVersionUrl;
    
/*
*********************************************************
@method Name    : getCustomMetadataType
@description    : This method is required by the Auth.AuthProviderPluginClass interface. It returns the API name
                  of the custom metadata type that holds the configuration for this authentication provider.
@return         : String The API name of the custom metadata type.
********************************************************
*/
    global String getCustomMetadataType() {
        return 'Auth0_Config__mdt';
    }
        
/*
*********************************************************
@method Name    : initiate
@description    : This method is the first step in the OAuth 2.0 flow. It constructs the URL to the Auth0
                  authorization endpoint and redirects the user's browser to that URL to initiate the login process.
@param          : authProviderConfiguration A map containing the configuration values from the custom metadata type.
@param          : stateToPropagate The unique state parameter generated by Salesforce to prevent CSRF attacks.
@return         : PageReference A PageReference object for the Auth0 authorization URL.
********************************************************
*/
    global PageReference initiate(Map<String, String> authProviderConfiguration, String stateToPropagate) {
        System.debug('=== AUTH PROVIDER CONFIGURATION ===');
        for (String key : authProviderConfiguration.keySet()) {
        }
        authUrl = authProviderConfiguration.get('Authorization_Endpoint_URL__c');
        key = authProviderConfiguration.get('App_ID__c');
        redirectUrl = authProviderConfiguration.get('Redirect_Url__c');
        
        // Validate required values to avoid nulls
        if (String.isBlank(authUrl) || String.isBlank(key) || String.isBlank(redirectUrl)) {
            return null;
        }
        
        // Define the desired post-login URL. This is the page users will see after logging in.
        String url = authUrl + '?response_type=code'
            + '&client_id=' + EncodingUtil.urlEncode(key, 'UTF-8')
            + '&scope=' + EncodingUtil.urlEncode('openid profile email', 'UTF-8')
            + '&redirect_uri=' + EncodingUtil.urlEncode(redirectUrl, 'UTF-8')
            + '&state=' + EncodingUtil.urlEncode(stateToPropagate, 'UTF-8');
        
        return new PageReference(url);
    }
/*
*********************************************************
@method Name    : handleCallback
@description    : This method is the callback handler that processes the response from Auth0. It takes the
                  authorization code returned by Auth0, exchanges it for an access token, and returns the token response to Salesforce.
@param          : authProviderConfiguration A map containing the configuration values from the custom metadata type.
@param          : state The Auth.AuthProviderCallbackState object containing query parameters from the callback URL.
@return         : Auth.AuthProviderTokenResponse An object containing the access token and the original state.
********************************************************
*/ 
    global Auth.AuthProviderTokenResponse handleCallback(Map<String,String> authProviderConfiguration, Auth.AuthProviderCallbackState state) {
        key = authProviderConfiguration.get('App_ID__c');
        secret = authProviderConfiguration.get('App_Secret__c');
        accessTokenUrl = authProviderConfiguration.get('Token_Endpoint_URL__c');
        redirectUrl = authProviderConfiguration.get('Redirect_Url__c');
        
        Map<String,String> queryParams = state.queryParameters;
        String code = queryParams.get('code');
        String sfdcState = queryParams.get('state');
        
        HttpRequest req = new HttpRequest();
        req.setEndpoint(accessTokenUrl);
        req.setHeader('Content-Type', 'application/x-www-form-urlencoded');
        req.setMethod('POST');
        
        String body = 'grant_type=authorization_code'
            + '&code=' + EncodingUtil.urlEncode(code, 'UTF-8')
            + '&client_id=' + EncodingUtil.urlEncode(key, 'UTF-8')
            + '&client_secret=' + EncodingUtil.urlEncode(secret, 'UTF-8')
            + '&redirect_uri=' + EncodingUtil.urlEncode(redirectUrl, 'UTF-8');
        req.setBody(body);
        
        Http http = new Http();
        HttpResponse res = http.send(req);
        String responseBody = res.getBody();
        
        String token = getTokenValueFromResponse(responseBody, 'access_token');
        
        // Pass the state along so we can use it in getUserInfo.
        return new Auth.AuthProviderTokenResponse('Auth0', token, 'refreshToken', sfdcState);
    }
    
/*
*********************************************************
@method Name    : getUserInfo
@description    : This method uses the access token to retrieve the user's profile information from the Auth0
                  user info endpoint. It parses the response and returns a standard Auth.UserData object for Salesforce to use.
@param          : authProviderConfiguration A map containing the configuration values from the custom metadata type.
@param          : response The Auth.AuthProviderTokenResponse object containing the access token and the state.
@return         : Auth.UserData An object containing the user's profile information.
********************************************************
*/
    global Auth.UserData getUserInfo(Map<String, String> authProviderConfiguration, Auth.AuthProviderTokenResponse response) {
        String token = response.oauthToken;
        
        HttpRequest req = new HttpRequest();
        String userInfoUrl = authProviderConfiguration.get('API_User_Url__c');
        req.setEndpoint(userInfoUrl);
        req.setHeader('Authorization', 'Bearer ' + token);
        req.setHeader('Content-Type', 'application/json');
        req.setMethod('GET');
        
        Http http = new Http();
        HttpResponse res = http.send(req);
        String responseBody = res.getBody();
        
        Map<String, Object> json = (Map<String, Object>) JSON.deserializeUntyped(responseBody);
        
        String id = (String) json.get('sub');
        String email = (String) json.get('email');
        String givenName = (String) json.get('given_name');
        String familyName = (String) json.get('family_name');
        String fullName = givenName + ' ' + familyName;
        String locale = (String) json.get('locale');
        
        Map<String, String> provMap = new Map<String, String>();
        provMap.put('provider', 'Auth0');
   
        String stateFromCallback = response.state;
        if (String.isNotBlank(stateFromCallback)) {
            List<String> stateParts = stateFromCallback.split('\\|\\|');
            if (stateParts.size() == 2) {
                provMap.put('sfdc_state', stateParts[0]);
                provMap.put('postLoginUrl', EncodingUtil.urlDecode(stateParts[1], 'UTF-8'));
            }
        }
        
        return new Auth.UserData(
            id,
            givenName,
            familyName,
            fullName,
            email,
            null, // link
            locale,
            null, // nickname
            'Auth0', // provider
            null, // photoUrl
            provMap // attributeMap with our custom state
        );
    }
 
/*
*********************************************************
@method Name    : getTokenValueFromResponse
@description    : A private helper method to safely extract a string value from a JSON response map.
                  It prevents errors by checking if the key exists before attempting to cast.
@param          : response The JSON string to deserialize.
@param          : token The key for which to retrieve the value.
@return         : String The extracted string value, or null if the key is not found.
*********************************************************
*/
    private String getTokenValueFromResponse(String response, String token) {
        Map<String, Object> jsonMap = (Map<String, Object>) JSON.deserializeUntyped(response);
        if (jsonMap.containsKey(token)) {
            return (String) jsonMap.get(token);
        }
        
        return null;
    }
}