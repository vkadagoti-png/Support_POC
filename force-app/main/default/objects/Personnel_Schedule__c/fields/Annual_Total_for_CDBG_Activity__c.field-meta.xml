<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Annual_Total_for_CDBG_Activity__c</fullName>
    <formula>Total_Annual_Salary__c * (
    (
        BLANKVALUE(Percent_Charged_to_CDBG_Activity__c, 0) + 
        BLANKVALUE(Percent_of_Time_Charged_to_Block_Grant__c, 0)
    ) 
  
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Total Annual Salary x Percent Charged to CDBG Activity</inlineHelpText>
    <label>Annual Total for CDBG Activity</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Currency</type>
</CustomField>
