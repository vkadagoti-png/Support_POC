<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Disbursed_Amount__c</fullName>
    <formula>Actual_Disbursed__c +  Pending_Disbursement__c + Total_Prior_Disbursed__c</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Displays the combined total of funds already disbursed, currently pending disbursement, and any prior disbursed amounts.</inlineHelpText>
    <label>Disbursed Amount</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <type>Currency</type>
</CustomField>
