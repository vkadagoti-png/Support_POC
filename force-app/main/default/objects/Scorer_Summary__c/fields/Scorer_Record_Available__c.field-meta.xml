<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Scorer_Record_Available__c</fullName>
    <description>This box will be check if a user is either assigned to the Scorer Record or the Owner of the Score Summary</description>
    <formula>(Assigned_Scorer__c = $User.Id) ||
(Score_Summary__r.OwnerId = $User.Id)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Scorer Record Available</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
