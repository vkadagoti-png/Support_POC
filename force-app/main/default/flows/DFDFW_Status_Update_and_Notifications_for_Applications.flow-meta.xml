    <decisions>
        <name>Service_Application_Status_Update_Notification</name>
        <label>Service Application Status Update Notification</label>
        <locationX>982</locationX>
        <locationY>323</locationY>
        <defaultConnectorLabel>No status change needed</defaultConnectorLabel>
        <rules>
            <name>Check_if_notification_needs_to_be_sent</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.OIC_Status__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.OIC_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OPEN</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Has_OIC_Status_Changed</targetReference>
            </connector>
            <label>Check if notification needs to be sent</label>
        </rules>
    </decisions>
