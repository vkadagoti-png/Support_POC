        </rules>
    </decisions>
    <decisions>
        <description>Check the prior value of the status to verify that the new value is not the same as the prior one, and that the prior value was not blank.</description>
        <name>Check_the_prior_values_of_Status</name>
        <label>Check the prior values of Status</label>
        <locationX>726</locationX>
        <locationY>839</locationY>
        <defaultConnectorLabel>Prior Status value blank and updated with same value</defaultConnectorLabel>
        <rules>
            <name>Status_changed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior.Status__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>$Record.Status__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Status__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Notification_Details</targetReference>
            </connector>
            <label>Status changed</label>
        </rules>
    </decisions>
    <decisions>
        <name>Has_OIC_Status_Changed</name>
        <label>Has OIC Status Changed</label>
        <locationX>726</locationX>
        <locationY>431</locationY>
        <defaultConnector>
            <targetReference>Check_the_prior_values_of_Status</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>OIC_Status_Changed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.OIC_Status__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.OIC_Status__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>DRAFT</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_OIC_to_Status_Mapping_Custom_Metadata_Types</targetReference>
            </connector>
            <label>OIC Status Changed</label>
        </rules>
    </decisions>
