<?xml version="1.0" encoding="UTF-8"?>
<SharingRules xmlns="http://soap.sforce.com/2006/04/metadata">
    <sharingCriteriaRules>
        <fullName>Budget_CDBG_Internal_Users</fullName>
        <accessLevel>Edit</accessLevel>
        <label>Budget - CDBG Internal Users</label>
        <sharedTo>
            <group>CDBG_Internal_Users</group>
        </sharedTo>
        <criteriaItems>
            <field>Name</field>
            <operation>notEqual</operation>
            <value></value>
        </criteriaItems>
        <includeRecordsOwnedByAll>true</includeRecordsOwnedByAll>
    </sharingCriteriaRules>
    <sharingCriteriaRules>
        <fullName>Budget_External_Users</fullName>
        <accessLevel>Edit</accessLevel>
        <label>Budget - External Users</label>
        <sharedTo>
            <allCustomerPortalUsers></allCustomerPortalUsers>
        </sharedTo>
        <criteriaItems>
            <field>Name</field>
            <operation>notEqual</operation>
            <value></value>
        </criteriaItems>
        <includeRecordsOwnedByAll>true</includeRecordsOwnedByAll>
    </sharingCriteriaRules>
    <sharingCriteriaRules>
        <fullName>Budget_Grantee_Portal_User_SR</fullName>
        <accessLevel>Edit</accessLevel>
        <label>Budget - Grantee Portal User SR</label>
        <sharedTo>
            <group>Grantee_Community_Portal_User</group>
        </sharedTo>
        <criteriaItems>
            <field>Name</field>
            <operation>notEqual</operation>
            <value></value>
        </criteriaItems>
        <includeRecordsOwnedByAll>true</includeRecordsOwnedByAll>
    </sharingCriteriaRules>
    <sharingCriteriaRules>
        <fullName>share_with_CDA</fullName>
        <accessLevel>Edit</accessLevel>
        <label>share with CDA</label>
        <sharedTo>
            <allInternalUsers></allInternalUsers>
        </sharedTo>
        <criteriaItems>
            <field>Type</field>
            <operation>equals</operation>
            <value>Project</value>
        </criteriaItems>
        <includeRecordsOwnedByAll>true</includeRecordsOwnedByAll>
    </sharingCriteriaRules>
    <sharingOwnerRules>
        <fullName>Budget_Sharing_for_internal</fullName>
        <accessLevel>Edit</accessLevel>
        <label>Budget Sharing for internal</label>
        <sharedTo>
            <roleAndSubordinatesInternal>System_Admin</roleAndSubordinatesInternal>
        </sharedTo>
        <sharedFrom>
            <role>System_Admin</role>
        </sharedFrom>
    </sharingOwnerRules>
    <sharingOwnerRules>
        <fullName>CDA_Budget_Sharing</fullName>
        <accessLevel>Edit</accessLevel>
        <label>CDA Budget Sharing</label>
        <sharedTo>
            <roleAndSubordinatesInternal>CDA</roleAndSubordinatesInternal>
        </sharedTo>
        <sharedFrom>
            <role>System_Admin</role>
        </sharedFrom>
    </sharingOwnerRules>
</SharingRules>
